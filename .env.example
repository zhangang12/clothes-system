# ============================================================
# I9 服装制造管理系统 — 生产环境变量模板
# 复制为 .env.production 并填写真实值
# setup.sh 会自动生成随机密钥版本
# ============================================================

# ===== 数据库（API 读取）=====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=i9_clothes
DB_USER=i9user
DB_PASS=                        # 必填，生产请使用随机字符串

# ===== Redis（API 读取）=====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                 # 必填，与 Docker Compose 中的 REDIS_PASSWORD 保持一致

# ===== JWT（API 读取）=====
JWT_SECRET=                     # 必填，至少 32 位随机字符串
JWT_EXPIRES=8h

# ===== 文件存储 =====
UPLOAD_ROOT=/data/uploads

# ===== 服务配置 =====
PORT=3000
NODE_ENV=production

# ===== CORS — 前端访问域名 =====
WEB_ORIGIN=https://your-domain.com
PORTAL_ORIGIN=https://your-domain.com

# ===== Docker Compose — 数据库初始化密码（与 DB_PASS 保持一致）=====
MYSQL_ROOT_PASSWORD=            # 必填
MYSQL_USER=i9user
MYSQL_PASSWORD=                 # 与 DB_PASS 相同
