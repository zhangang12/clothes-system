# ============================================================
# I9 服装制造管理系统 - 环境变量示例
# 复制此文件为 .env.local 并填写真实值
# ============================================================

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=i9_clothes
DB_USER=i9user
DB_PASS=i9pass123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# JWT
JWT_SECRET=change-me-in-production-use-32-char-random-string
JWT_EXPIRES=8h

# 文件存储
UPLOAD_ROOT=/data/uploads

# 服务端口
PORT=3000
NODE_ENV=development

# 前端 CORS（生产环境）
WEB_ORIGIN=https://your-domain.com
PORTAL_ORIGIN=https://portal.your-domain.com
